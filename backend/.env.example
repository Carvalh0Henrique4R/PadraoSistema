AUTH_SECRET="" # Generate a strong secret (e.g., via openssl rand -base64 32)

DATABASE_URL=postgresql://user:password@localhost:5432/dbname

ENVIRONMENT=development
# Must match the origin you open in the browser (scheme + host + port), e.g. http://127.0.0.1:5173 if you use 127.0.0.1
FRONTEND_URL=http://localhost:5173
# Optional; defaults to FRONTEND_URL origin + /api/auth. In dev, the server also syncs this from the Vite proxy (Forwarded / Origin / Referer).
# AUTH_URL=http://localhost:5173/api/auth

GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

OAUTH_TOKEN_ENCRYPTION_KEY="" # Encrypts OAuth tokens at rest (e.g., via openssl rand -base64 32)

PORT=3000
